# Copy to /etc/alert-list-bot/alert-list-bot.env on alerts-primary with mode 0600.
ALERTMANAGER_URL=http://127.0.0.1:9093
METRICS_URL_TENANT_1=http://vmselect.example.net/select/1/prometheus
# METRICS_URL_TENANT_0=http://vmselect.example.net/select/0/prometheus
TELEGRAM_BOT_TOKEN=replace-me
TELEGRAM_ALLOWED_CHAT_IDS=123456789
HTTP_TIMEOUT=45s
TELEGRAM_POLL_TIMEOUT=30s
RETRY_DELAY=2s
TELEGRAM_EXPANDABLE_QUOTES=true
